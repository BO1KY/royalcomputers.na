# Admin password SHA-256 hash
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('yourpassword').digest('hex'))"
ADMIN_PASSWORD_HASH=b9566066d2a1fb5f1be75fd7c302049c155a89343d9dcc06813f427c19211be3

# Server port (optional, default 3000)
PORT=3000

# Database path (optional, default: server/data.db)
# For production, set this to a persistent path outside the project directory
# so subscriber data survives deployments/restarts
DB_PATH=

# SMTP settings for email campaigns (send promotions/sales/new to subscribers)
# For Gmail: use an App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=royalcomputers.na@gmail.com
SMTP_PASS=your-app-password-here

# Allowed CORS origins (optional, comma-separated)
# Leave empty to allow same-origin requests only
# Example: https://netmac.co.za,https://admin.netmac.co.za
ALLOWED_ORIGINS=
